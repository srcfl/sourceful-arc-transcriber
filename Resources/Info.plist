<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Display name stays "Arc Transcriber"; bundle identifier and
         CFBundleExecutable intentionally stay as `*.transcriber` /
         `Transcriber` so existing v0.0.1 installs keep their TCC /
         Keychain grants and the auto-updater can still find them by
         bundle id. -->
    <key>CFBundleExecutable</key>
    <string>Transcriber</string>
    <key>CFBundleIdentifier</key>
    <string>io.srcful.transcriber</string>
    <key>CFBundleName</key>
    <string>Arc Transcriber</string>
    <key>CFBundleDisplayName</key>
    <string>Arc Transcriber</string>
    <key>CFBundleIconFile</key>
    <string>iconfile</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSMicrophoneUsageDescription</key>
    <string>Arc Transcriber records microphone audio locally to transcribe meetings and voice notes.</string>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>io.srcful.transcriber.auth</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>sourceful-transcriber</string>
            </array>
        </dict>
    </array>
</dict>
</plist>

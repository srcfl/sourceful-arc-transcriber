<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required by WhisperKit + FluidAudio: both load CoreML models
         at runtime via Apple's Accelerate / Metal frameworks.
         Hardened runtime refuses this without the flag. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Arc API calls + GitHub Releases polling for auto-update. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Explicit mic entitlement. For non-sandboxed hardened-runtime
         apps this wasn't historically required — TCC was supposed to
         gate mic access purely off NSMicrophoneUsageDescription. On
         macOS 15+ we observed signed / notarized / quarantine-clean
         installs where `AVCaptureDevice.requestAccess` still returned
         denied *and* the app never appeared in System Settings →
         Microphone. Adding this flag is what makes TCC register the
         request and show the prompt. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
